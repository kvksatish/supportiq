# Browser-visible API base. Leave empty to use same-origin requests through Next/nginx.
NEXT_PUBLIC_API_BASE_URL=

# Browser-visible WebSocket base. In local dev, point directly at the FastAPI backend.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Server-side proxy target used by Next.js rewrites in local/dev container environments.
BACKEND_PROXY_TARGET=http://localhost:8000
